\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{style_minimal}

\RequirePackage[margin=0.75in,top=0.7in,bottom=0.7in]{geometry}
\RequirePackage[T1]{fontenc}
\RequirePackage{xcolor}
\RequirePackage{tcolorbox}
\RequirePackage{titlesec}
\RequirePackage{tabularx}
\RequirePackage{enumitem}
\RequirePackage{listings}
\RequirePackage{hyperref}
\RequirePackage{fancyhdr}
\RequirePackage{parskip}
\RequirePackage{booktabs}

\tcbuselibrary{skins,breakable}

\definecolor{gray10}{gray}{0.10}
\definecolor{gray30}{gray}{0.30}
\definecolor{gray60}{gray}{0.60}
\definecolor{gray85}{gray}{0.85}
\definecolor{gray95}{gray}{0.95}

\hypersetup{
    colorlinks=true,
    linkcolor=black,
    urlcolor=black,
    citecolor=black
}

\titleformat{\section}{\large\bfseries}{\thesection}{0.8em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{0.7em}{}
\titleformat{\subsubsection}{\normalsize\bfseries\itshape}{\thesubsubsection}{0.6em}{}

\titlespacing*{\section}{0pt}{1.4ex plus 0.3ex}{0.6ex}
\titlespacing*{\subsection}{0pt}{1.1ex plus 0.2ex}{0.4ex}
\titlespacing*{\subsubsection}{0pt}{0.9ex plus 0.2ex}{0.3ex}

\setlist{nosep, leftmargin=1.3em, topsep=2pt, partopsep=0pt}
\setlist[itemize]{label=\textbullet}
\setlist[enumerate]{label=\arabic*.}

\newtcolorbox{notebox}[1][]{
  colback=gray95, colframe=black,
  fonttitle=\bfseries, title=#1,
  breakable, enhanced,
  boxrule=0.4pt, sharp corners,
  left=5pt, right=5pt, top=3pt, bottom=3pt,
  before skip=6pt, after skip=6pt
}

\newtcolorbox{codebox}[1][]{
  colback=gray95, colframe=gray60,
  breakable, enhanced,
  boxrule=0.3pt, sharp corners,
  left=5pt, right=5pt, top=3pt, bottom=3pt,
  before skip=5pt, after skip=5pt
}

\lstset{
  basicstyle=\footnotesize\ttfamily,
  breaklines=true, frame=none,
  backgroundcolor=\color{gray95},
  keywordstyle=\bfseries,
  commentstyle=\itshape\color{gray30},
  showstringspaces=false,
  tabsize=2,
  xleftmargin=2pt, xrightmargin=2pt
}

\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0.3pt}
\renewcommand{\footrulewidth}{0.3pt}

\newcommand{\projecttitle}[2]{%
  \begin{center}
    {\Large\bfseries #1}\\[3pt]
    {\small Advanced Database Management --- Computer Science (A \& B), 4th Semester}\\[2pt]
    {\small\itshape Project 02 Manual \hspace{0.8em}|\hspace{0.8em} Languages: #2}\\[2pt]
    % {\small Academic Year 2026}
  \end{center}
  \vspace{-0.3em}\hrule height 0.4pt\vspace{0.5em}
}

