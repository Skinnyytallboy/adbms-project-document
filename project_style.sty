\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{project_style}

\RequirePackage[margin=1in]{geometry}
\RequirePackage[T1]{fontenc}
\RequirePackage{xcolor}
\RequirePackage{tcolorbox}
\RequirePackage{titlesec}
\RequirePackage{tabularx}
\RequirePackage{enumitem}
\RequirePackage{listings}
\RequirePackage{hyperref}
\RequirePackage{fancyhdr}
\RequirePackage{parskip}

\tcbuselibrary{skins,breakable}

\definecolor{primaryblue}{HTML}{1A5276}
\definecolor{lightblue}{HTML}{D6EAF8}
\definecolor{darkblue}{HTML}{154360}
\definecolor{accentgreen}{HTML}{1E8449}
\definecolor{lightgreen}{HTML}{D5F5E3}
\definecolor{warningred}{HTML}{922B21}
\definecolor{lightred}{HTML}{FADBD8}
\definecolor{lightgray}{HTML}{F2F3F4}
\definecolor{codegray}{HTML}{F8F9F9}
\definecolor{orange}{HTML}{E67E22}
\definecolor{lightorange}{HTML}{FDEBD0}

\hypersetup{
    colorlinks=true,
    linkcolor=primaryblue,
    urlcolor=primaryblue,
    citecolor=primaryblue
}

\titleformat{\section}
  {\Large\bfseries\color{primaryblue}}
  {\thesection}{1em}{}
\titleformat{\subsection}
  {\large\bfseries\color{darkblue}}
  {\thesubsection}{1em}{}
\titleformat{\subsubsection}
  {\normalsize\bfseries\color{darkblue}}
  {\thesubsubsection}{1em}{}

\titlespacing*{\section}{0pt}{1.5ex plus 0.5ex}{0.8ex plus 0.2ex}
\titlespacing*{\subsection}{0pt}{1.2ex plus 0.3ex}{0.5ex plus 0.1ex}
\titlespacing*{\subsubsection}{0pt}{1ex plus 0.2ex}{0.4ex plus 0.1ex}

\setlist{nosep, leftmargin=1.5em}
\setlist[itemize]{label=\textbullet}
\setlist[enumerate]{label=\arabic*.}

\newtcolorbox{infobox}[1][]{
  colback=lightblue,
  colframe=primaryblue,
  fonttitle=\bfseries,
  title=#1,
  breakable,
  enhanced,
  boxrule=0.5pt,
  left=6pt, right=6pt, top=4pt, bottom=4pt,
  before skip=8pt, after skip=8pt
}

\newtcolorbox{warningbox}[1][]{
  colback=lightred,
  colframe=warningred,
  fonttitle=\bfseries,
  title=#1,
  breakable,
  enhanced,
  boxrule=0.5pt,
  left=6pt, right=6pt, top=4pt, bottom=4pt,
  before skip=8pt, after skip=8pt
}

\newtcolorbox{successbox}[1][]{
  colback=lightgreen,
  colframe=accentgreen,
  fonttitle=\bfseries,
  title=#1,
  breakable,
  enhanced,
  boxrule=0.5pt,
  left=6pt, right=6pt, top=4pt, bottom=4pt,
  before skip=8pt, after skip=8pt
}

\newtcolorbox{notebox}[1][]{
  colback=lightorange,
  colframe=orange,
  fonttitle=\bfseries,
  title=#1,
  breakable,
  enhanced,
  boxrule=0.5pt,
  left=6pt, right=6pt, top=4pt, bottom=4pt,
  before skip=8pt, after skip=8pt
}

\newtcolorbox{codebox}[1][]{
  colback=codegray,
  colframe=black!30,
  fonttitle=\bfseries\ttfamily,
  title=#1,
  breakable,
  enhanced,
  boxrule=0.4pt,
  left=6pt, right=6pt, top=4pt, bottom=4pt
}

\lstset{
  basicstyle=\small\ttfamily,
  breaklines=true,
  frame=none,
  backgroundcolor=\color{codegray},
  keywordstyle=\color{primaryblue}\bfseries,
  commentstyle=\color{accentgreen},
  stringstyle=\color{warningred},
  showstringspaces=false,
  tabsize=4,
  xleftmargin=4pt,
  xrightmargin=4pt
}

\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\footrulewidth}{0.4pt}

\newcommand{\projecttitle}[4]{%
  \begin{center}
    {\LARGE\bfseries\color{primaryblue} #1}\\[6pt]
    {\large Advanced Database Management Course}\\[2pt]
    {\normalsize Computer Science (A \& B) --- 4th Semester}\\[2pt]
    {\normalsize\bfseries Project Manual \& Requirements}\\[6pt]
    {\small Team Size: 3 members \quad|\quad Duration: #2 \quad|\quad Difficulty: #3}\\[2pt]
    {\small Languages: #4}\\[2pt]
    {\small Academic Year 2026}
  \end{center}
  \vspace{0.5em}
  \hrule height 0.5pt
  \vspace{1em}
}

